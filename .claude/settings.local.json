{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Skill(update-config)",
      "mcp__plugin_ecc_exa__web_search_exa",
      "Bash(bash D:/dev/MyAssetManager/.claude/hooks/git-flow-guard.sh)",
      "Bash(echo \"exit: $?\")",
      "Bash(echo \"push 허용 확인 \\(출력 없으면 통과\\): exit $?\")",
      "Bash(curl:*)",
      "Bash(grep -r \"trustHost\" D:/dev/MyAssetManager/node_modules/next-auth/types* D:/dev/MyAssetManager/node_modules/@auth/core/types*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/dev/MyAssetManager/.claude/hooks/git-flow-guard.sh",
            "statusMessage": "Git Flow 보호 브랜치 검사 중..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ecc@ecc": true,
    "skill-creator@claude-plugins-official": true
  }
}
