{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "statusMessage": "Git Flow 브랜치 상태 확인 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-flow-guard.sh",
            "statusMessage": "Git Flow 보호 브랜치 검사 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop.sh",
            "statusMessage": "세션 종료 보안 검사 중..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ecc@ecc": true
  }
}
