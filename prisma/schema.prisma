generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  password           String?
  cashBalance        Float               @default(0)
  targetAllocations  String?
  holdings           Holding[]
  transactions       Transaction[]
  cashAccounts       CashAccount[]
  snapshots          PortfolioSnapshot[]
  createdAt          DateTime            @default(now())
}

model PortfolioSnapshot {
  id         String   @id @default(cuid())
  userId     String
  totalValue Float
  snapDate   DateTime
  breakdown  String   // JSON: { stockRatio, cryptoRatio, cashRatio }
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holding {
  id           String        @id @default(cuid())
  userId       String
  ticker       String
  assetType    String
  quantity     Float
  avgCost      Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  name         String?
  exchange     String?
  currency     String?
  purchaseDate DateTime?
  memo         String?

  @@unique([userId, ticker])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  holdingId String
  ticker    String
  assetType String
  type      String   // 'BUY' | 'SELL'
  quantity  Float
  price     Float
  fee       Float?
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())
  currency  String   @default("KRW")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
}

model CashAccount {
  id           String    @id @default(cuid())
  userId       String
  institution  String
  accountType  String
  amount       Float
  interestRate Float?
  maturityDate DateTime?
  memo         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
